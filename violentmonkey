// ==UserScript==
// @name         Monkeytype Auto Typer (Simple, Fast, Accurate)
// @namespace    https://monkeytype.com/
// @version      3.0.0
// @description  Fast and simple Monkeytype auto-typer that follows active letters for mode accuracy and maintains target WPM.
// @author       You
// @match        https://monkeytype.com/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    const SETTINGS = {
        targetWpm: 3000,
        maxIntentionalErrors: 0,
        autoStart: true,
        schedulerIntervalMs: 10,
        maxBurstPerTick: 40,
        hotkey: {
            ctrlKey: true,
            altKey: true,
            shiftKey: false,
            key: 's'
        }
    };

    const engine = {
        running: false,
        intentionalErrorsUsed: 0,
        charDebt: 0,
        lastTick: 0,
        loopTimer: null
    };

    function getInput() {
        return document.querySelector('#wordsInput');
    }

    function getActiveWord() {
        return document.querySelector('#words .word.active');
    }

    function canType() {
        return Boolean(getInput() && getActiveWord());
    }

    function msPerCharacter() {
        const safeWpm = Math.max(1, Number(SETTINGS.targetWpm) || 1);
        return 60000 / (safeWpm * 5);
    }

    function getNextUntypedLetter() {
        const activeWord = getActiveWord();
        if (!activeWord) return null;

        const letters = activeWord.querySelectorAll('letter');
        for (const letter of letters) {
            const typed = letter.classList.contains('correct') || letter.classList.contains('incorrect');
            if (!typed) return letter;
        }

        return null;
    }

    function nextErrorCharacter(char) {
        if (!char) return '';
        if (/[a-z]/.test(char)) return char === 'z' ? 'a' : String.fromCharCode(char.charCodeAt(0) + 1);
        if (/[A-Z]/.test(char)) return char === 'Z' ? 'A' : String.fromCharCode(char.charCodeAt(0) + 1);
        if (/[0-9]/.test(char)) return char === '9' ? '0' : String.fromCharCode(char.charCodeAt(0) + 1);
        return 'x';
    }

    function getExpectedCharacter() {
        const letter = getNextUntypedLetter();
        if (!letter) return ' ';

        let character = (letter.textContent || '').replace(/\u00A0/g, ' ');
        if (!character) return '';

        if (
            SETTINGS.maxIntentionalErrors > 0 &&
            engine.intentionalErrorsUsed < SETTINGS.maxIntentionalErrors &&
            /\S/.test(character)
        ) {
            engine.intentionalErrorsUsed += 1;
            character = nextErrorCharacter(character);
        }

        return character;
    }

    function emitText(input, text) {
        const keyboardInit = {
            key: text,
            code: text === ' ' ? 'Space' : undefined,
            bubbles: true,
            cancelable: true,
            composed: true
        };

        input.dispatchEvent(new KeyboardEvent('keydown', keyboardInit));

        input.dispatchEvent(new InputEvent('beforeinput', {
            bubbles: true,
            cancelable: true,
            composed: true,
            data: text,
            inputType: 'insertText'
        }));

        if (document.execCommand) {
            document.execCommand('insertText', false, text);
        }

        input.dispatchEvent(new InputEvent('input', {
            bubbles: true,
            cancelable: false,
            composed: true,
            data: text,
            inputType: 'insertText'
        }));

        input.dispatchEvent(new KeyboardEvent('keyup', keyboardInit));
    }

    function typeOneCharacter() {
        const input = getInput();
        if (!input) return false;

        if (document.activeElement !== input) {
            input.focus();
        }

        const character = getExpectedCharacter();
        if (!character) return false;

        emitText(input, character);
        return true;
    }

    function stopTyping(reason) {
        if (!engine.running) return;

        engine.running = false;
        if (engine.loopTimer) {
            clearInterval(engine.loopTimer);
            engine.loopTimer = null;
        }
        console.info(`[Monkeytype Auto Typer] Stopped: ${reason}`);
    }

    function tick() {
        if (!engine.running) return;

        if (!canType()) {
            stopTyping('No active test detected');
            return;
        }

        const now = performance.now();
        const elapsed = Math.max(0, now - engine.lastTick);
        engine.lastTick = now;

        engine.charDebt += elapsed / msPerCharacter();

        let toType = Math.floor(engine.charDebt);
        if (toType <= 0) return;

        toType = Math.min(toType, SETTINGS.maxBurstPerTick);
        let typed = 0;

        while (typed < toType) {
            if (!typeOneCharacter()) break;
            typed += 1;
        }

        engine.charDebt = Math.max(0, engine.charDebt - typed);
    }

    function startTyping() {
        if (engine.running || !canType()) return;

        engine.running = true;
        engine.intentionalErrorsUsed = 0;
        engine.charDebt = 0;
        engine.lastTick = performance.now();

        engine.loopTimer = window.setInterval(tick, SETTINGS.schedulerIntervalMs);
        console.info(`[Monkeytype Auto Typer] Started at ${SETTINGS.targetWpm} WPM`);
    }

    function matchesHotkey(event) {
        const configuredKey = String(SETTINGS.hotkey.key || '').toLowerCase();
        return (
            String(event.key || '').toLowerCase() === configuredKey &&
            Boolean(event.ctrlKey) === Boolean(SETTINGS.hotkey.ctrlKey) &&
            Boolean(event.altKey) === Boolean(SETTINGS.hotkey.altKey) &&
            Boolean(event.shiftKey) === Boolean(SETTINGS.hotkey.shiftKey)
        );
    }

    document.addEventListener('keydown', (event) => {
        if (!matchesHotkey(event)) return;

        event.preventDefault();
        if (engine.running) {
            stopTyping('Hotkey toggle');
        } else {
            startTyping();
        }
    });

    if (SETTINGS.autoStart) {
        const observer = new MutationObserver(() => {
            if (!engine.running && canType()) startTyping();
        });

        observer.observe(document.body, { childList: true, subtree: true });

        window.setInterval(() => {
            if (!engine.running && canType()) startTyping();
        }, 120);
    }

    console.info('[Monkeytype Auto Typer] Loaded. Toggle with Ctrl+Alt+S.');
})();
