// ==UserScript==
// @name         Monkeytype Auto Typer (Accurate, Mode-Compatible)
// @namespace    https://monkeytype.com/
// @version      2.0.0
// @description  Types exactly what Monkeytype expects across words, quotes, punctuation, and numbers modes. For educational/testing purposes only.
// @author       You
// @match        https://monkeytype.com/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    const SETTINGS = {
        targetWpm: 180,
        maxIntentionalErrors: 0,
        autoStart: true,
        pollIntervalMs: 250,
        verificationTimeoutMs: 900,
        hotkey: {
            ctrlKey: true,
            altKey: true,
            shiftKey: false,
            key: 's'
        }
    };

    const SELECTORS = {
        activeWord: '#words .word.active',
        activeLetters: 'letter',
        wordsInput: '#wordsInput'
    };

    const engine = {
        running: false,
        intentionalErrorsUsed: 0,
        lastTypedAt: 0
    };

    function msPerCharacter() {
        const safeWpm = Math.max(1, Number(SETTINGS.targetWpm) || 1);
        return 60000 / (safeWpm * 5);
    }

    function getWordsInput() {
        return document.querySelector(SELECTORS.wordsInput);
    }

    function getActiveWord() {
        return document.querySelector(SELECTORS.activeWord);
    }

    function canType() {
        return !!getActiveWord() && !!getWordsInput();
    }

    function getNextUntypedLetterNode() {
        const activeWord = getActiveWord();
        if (!activeWord) return null;

        const letters = activeWord.querySelectorAll(SELECTORS.activeLetters);
        for (const letter of letters) {
            const typed = letter.classList.contains('correct') || letter.classList.contains('incorrect');
            if (!typed) return letter;
        }

        return null;
    }

    function nextErrorCharacter(char) {
        if (!char) return char;

        if (/[a-z]/.test(char)) {
            return char === 'z' ? 'a' : String.fromCharCode(char.charCodeAt(0) + 1);
        }
        if (/[A-Z]/.test(char)) {
            return char === 'Z' ? 'A' : String.fromCharCode(char.charCodeAt(0) + 1);
        }
        if (/[0-9]/.test(char)) {
            return char === '9' ? '0' : String.fromCharCode(char.charCodeAt(0) + 1);
        }

        return 'x';
    }

    function dispatchKeyboardEvents(target, key) {
        const eventInit = {
            key,
            code: key === ' ' ? 'Space' : undefined,
            bubbles: true,
            cancelable: true,
            composed: true
        };

        target.dispatchEvent(new KeyboardEvent('keydown', eventInit));
        target.dispatchEvent(new KeyboardEvent('keypress', eventInit));
        target.dispatchEvent(new KeyboardEvent('keyup', eventInit));
    }

    function dispatchInput(target, text) {
        const beforeInput = new InputEvent('beforeinput', {
            bubbles: true,
            cancelable: true,
            composed: true,
            data: text,
            inputType: 'insertText'
        });
        target.dispatchEvent(beforeInput);

        const inserted = document.execCommand && document.execCommand('insertText', false, text);

        if (!inserted) {
            target.value = (target.value || '') + text;
            target.dispatchEvent(new InputEvent('input', {
                bubbles: true,
                cancelable: false,
                composed: true,
                data: text,
                inputType: 'insertText'
            }));
        }
    }

    function typeCharacter(char) {
        const input = getWordsInput();
        if (!input) return false;

        input.focus();
        dispatchKeyboardEvents(input, char);
        dispatchInput(input, char);
        engine.lastTypedAt = performance.now();
        return true;
    }

    function calculateCharacterToType(letterNode) {
        let character = letterNode?.textContent ?? '';

        if (!character) return '';
        character = character.replace(/\u00A0/g, ' ');

        if (
            SETTINGS.maxIntentionalErrors > 0 &&
            engine.intentionalErrorsUsed < SETTINGS.maxIntentionalErrors &&
            /\S/.test(character)
        ) {
            engine.intentionalErrorsUsed += 1;
            return nextErrorCharacter(character);
        }

        return character;
    }

    function stopTyping(reason) {
        if (!engine.running) return;
        engine.running = false;
        console.info(`[Monkeytype Auto Typer] Stopped: ${reason}`);
    }

    function runStep() {
        if (!engine.running) return;

        if (!canType()) {
            stopTyping('No active test detected');
            return;
        }

        const nextLetter = getNextUntypedLetterNode();

        if (!nextLetter) {
            typeCharacter(' ');
            window.setTimeout(runStep, msPerCharacter());
            return;
        }

        const expectedChar = calculateCharacterToType(nextLetter);
        if (!expectedChar) {
            window.setTimeout(runStep, 16);
            return;
        }

        typeCharacter(expectedChar);

        const startedAt = performance.now();
        const verifyTyped = () => {
            if (!engine.running) return;

            const wasMarked = nextLetter.classList.contains('correct') || nextLetter.classList.contains('incorrect');
            if (wasMarked) {
                window.setTimeout(runStep, msPerCharacter());
                return;
            }

            if (performance.now() - startedAt > SETTINGS.verificationTimeoutMs) {
                window.setTimeout(runStep, msPerCharacter());
                return;
            }

            requestAnimationFrame(verifyTyped);
        };

        requestAnimationFrame(verifyTyped);
    }

    function startTyping() {
        if (engine.running) return;
        if (!canType()) return;

        engine.running = true;
        engine.intentionalErrorsUsed = 0;
        engine.lastTypedAt = performance.now();
        console.info(`[Monkeytype Auto Typer] Started at ${SETTINGS.targetWpm} WPM`);
        runStep();
    }

    function matchesHotkey(event) {
        const configuredKey = String(SETTINGS.hotkey.key || '').toLowerCase();
        return (
            event.key.toLowerCase() === configuredKey &&
            Boolean(event.ctrlKey) === Boolean(SETTINGS.hotkey.ctrlKey) &&
            Boolean(event.altKey) === Boolean(SETTINGS.hotkey.altKey) &&
            Boolean(event.shiftKey) === Boolean(SETTINGS.hotkey.shiftKey)
        );
    }

    function setupHotkey() {
        document.addEventListener('keydown', (event) => {
            if (!matchesHotkey(event)) return;

            event.preventDefault();
            if (engine.running) {
                stopTyping('Hotkey toggle');
            } else {
                startTyping();
            }
        });
    }

    function setupAutoStart() {
        if (!SETTINGS.autoStart) return;

        const observer = new MutationObserver(() => {
            if (!engine.running && canType()) {
                startTyping();
            }
        });

        observer.observe(document.body, { childList: true, subtree: true });

        window.setInterval(() => {
            if (!engine.running && canType()) {
                startTyping();
            }
        }, SETTINGS.pollIntervalMs);
    }

    setupHotkey();
    setupAutoStart();

    console.info('[Monkeytype Auto Typer] Loaded. Toggle with Ctrl+Alt+S.');
})();
