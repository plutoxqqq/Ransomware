// ==UserScript==
// @name Monkeytype Typing - v14 True WPM, Zero Errors, Auto-Space
// @namespace http://tampermonkey.net/
// @version 1.4
// @description Character-accurate, DOM-synced, error-proof typing with real WPM control (for fun only)
// @author You
// @match https://monkeytype.com/*
// @grant none
// @run-at document-end
// ==/UserScript==

(function() {
    'use strict';

    // ───────────── SETTINGS ─────────────
    const TARGET_WPM = 5000; // ← this now scales correctly
    const NUMBER_OF_ERRORS = 0;

    // ms per character (5 chars per word)
    const MS_PER_CHAR = 60000 / (TARGET_WPM * 5);

    let isTyping = false;
    let errorsMade = 0;

    function canType() {
        return !!document.querySelector('#words .word.active');
    }

    function getNextLetterNode() {
        const active = document.querySelector('.word.active');
        if (!active) return null;
        const letters = active.querySelectorAll('letter');
        for (let l of letters) {
            if (!l.classList.contains('correct') &&
                !l.classList.contains('incorrect')) {
                return l;
            }
        }
        return null;
    }

    function pressKey(char) {
        const el = document.getElementById('wordsInput');
        if (!el) return;
        el.focus?.();

        if (document.execCommand('insertText', false, char)) return;

        const ev = new InputEvent('input', { bubbles: true, data: char, inputType: 'insertText' });
        el.dispatchEvent(ev);

        ['keydown','keypress','keyup'].forEach(type => {
            el.dispatchEvent(new KeyboardEvent(type, { key: char, bubbles: true }));
        });
    }

    function typeNext() {
        if (!isTyping || !canType()) {
            isTyping = false;
            return;
        }

        let letterNode = getNextLetterNode();

        // If no letters left → type space
        if (!letterNode) {
            pressKey(' ');
            return setTimeout(typeNext, MS_PER_CHAR);
        }

        let char = letterNode.textContent || '';

        // optional errors
        if (NUMBER_OF_ERRORS > 0 &&
            errorsMade < NUMBER_OF_ERRORS &&
            /[a-zA-Z]/.test(char)) {
            errorsMade++;
            char = String.fromCharCode(char.charCodeAt(0) + 1);
        }

        pressKey(char);

        // Wait for Monkeytype to mark the letter before continuing
        const check = () => {
            if (letterNode.classList.contains('correct') ||
                letterNode.classList.contains('incorrect')) {
                setTimeout(typeNext, MS_PER_CHAR);
            } else {
                requestAnimationFrame(check);
            }
        };
        requestAnimationFrame(check);
    }

    function startTyping() {
        if (isTyping) return;
        isTyping = true;
        errorsMade = 0;
        typeNext();
    }

    new MutationObserver(() => {
        if (canType() && !isTyping) startTyping();
    }).observe(document.body, { childList: true, subtree: true });

    setInterval(() => {
        if (canType() && !isTyping) startTyping();
    }, 300);

    console.log(`[MT v14] Loaded – True WPM: ${TARGET_WPM}, Zero Errors`);
})();
